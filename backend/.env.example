# Backend
DATABASE_URL=postgres://catraca:catraca@localhost:5432/catraca?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-refresh
STRIPE_SECRET_KEY=
# Set true only after enabling PIX in Stripe Dashboard → Settings → Payment methods (Brazil). If false or unset, Checkout uses card only and avoids "pix is invalid" API errors.
STRIPE_CHECKOUT_ENABLE_PIX=false
# For Pix webhooks: ensure Pix is enabled as above (BRL Checkout line items only).
# Required for webhook signature verification. In Stripe Dashboard create an endpoint pointing to
# https://YOUR_PUBLIC_API_HOST/webhooks/stripe (POST) and subscribe at minimum to:
#   - charge.succeeded (resolves order_id via PaymentIntent metadata when not on the Charge)
#   - payment_intent.succeeded
#   - payment_intent.payment_failed
# Optional but recommended for Checkout: checkout.session.completed (fulfillment also runs from this event if session metadata includes order_id).
STRIPE_WEBHOOK_SECRET=
# Stripe Checkout redirect URLs (must include {CHECKOUT_SESSION_ID} in success URL — Stripe replaces it).
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/checkout?canceled=1
APP_ENV=development
PORT=8080
APP_SEED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000
CPF_PEPPER=change-me-in-production-cpf-pepper
PHONE_ENCRYPTION_KEY=change-me-in-production-phone-key
