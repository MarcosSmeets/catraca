# Backend
DATABASE_URL=postgres://catraca:catraca@localhost:5432/catraca?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-refresh
STRIPE_SECRET_KEY=
# Required for webhook signature verification. In Stripe Dashboard create an endpoint pointing to
# https://YOUR_PUBLIC_API_HOST/webhooks/stripe (POST) and subscribe to payment_intent.succeeded (PIX confirms asynchronously).
STRIPE_WEBHOOK_SECRET=
APP_ENV=development
PORT=8080
APP_SEED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000
CPF_PEPPER=change-me-in-production-cpf-pepper
PHONE_ENCRYPTION_KEY=change-me-in-production-phone-key
