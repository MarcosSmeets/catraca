# Copy to .env.local for local development.

# Base URL for all browser API calls. Must be the same origin as the Next app so the backend
# can set HttpOnly refresh_token cookies that middleware (same host) can read.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# Slug da organização usada na home / busca pública (ex.: legado após migração).
NEXT_PUBLIC_DEFAULT_ORG_SLUG=legado

# Go API URL used only by Next.js rewrites (server-side proxy). Not exposed to the browser.
BACKEND_URL=http://localhost:8080

# --- Production (Railway / Docker build) ---
# NEXT_PUBLIC_API_URL=https://YOUR-FRONTEND-PUBLIC-HOST/api
# BACKEND_URL=http://YOUR-BACKEND-SERVICE.railway.internal:8080
# (Use the internal hostname Railway assigns to the Go service, not the public backend URL.)
